{
  "architecture": "Xception-TCNSC",
  "num_classes": 6,
  "class_names": [
    "Original",
    "Deepfakes",
    "Face2Face",
    "FaceShifter",
    "FaceSwap",
    "NeuralTextures"
  ],
  "original_class_idx": 0,
  "binary_rule": "fake_prob = 1 - P(original), if fake_prob >= threshold => FAKE else REAL",
  "threshold_default": 0.5,
  "image_size": 299,
  "normalize_mean": [
    0.485,
    0.456,
    0.406
  ],
  "normalize_std": [
    0.229,
    0.224,
    0.225
  ],
  "compression_range": [
    10,
    40
  ],
  "similarity_loss": "cosine_distance",
  "lambda_sim": 0.08
}